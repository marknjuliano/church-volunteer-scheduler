rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUserExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return currentUserExists() && currentUser().data.role == "admin";
    }

    function isCoordinator() {
      return currentUserExists() && currentUser().data.role == "coordinator";
    }

    match /usernames/{username} {
      // Required so the login page can resolve an exact username before authentication.
      // Listing the username directory is never allowed.
      allow get: if true;
      allow list: if false;

      allow create: if signedIn()
        && !exists(/databases/$(database)/documents/usernames/$(username))
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == username
        && request.resource.data.loginEmail == request.auth.token.email;

      allow update: if false;

      allow delete: if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;

      allow read: if signedIn()
        && (request.auth.uid == userId || isAdmin() || isCoordinator());

      allow update: if isAdmin()
        || (
          signedIn()
          && request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status
        )
        || (
          isCoordinator()
          && resource.data.role in ["volunteer", "volunteerS"]
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["name", "updatedAt"])
        );

      allow delete: if isAdmin();
    }

    match /ministries/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /roles/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /services/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || isCoordinator();
    }

    match /assignments/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || isCoordinator();
    }

    match /settings/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
